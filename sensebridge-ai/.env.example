# ─── Server ───────────────────────────────────────────────────────
FLASK_PORT=8000
FLASK_HOST=0.0.0.0
FLASK_DEBUG=False

# ─── YOLO ─────────────────────────────────────────────────────────
YOLO_MODEL_PATH=models/yolo/sensebridge_yolov8n.pt
YOLO_ONNX_PATH=models/yolo/sensebridge_yolov8n.onnx
YOLO_CONF_THRESHOLD=0.45
YOLO_IOU_THRESHOLD=0.5
YOLO_IMGSZ=640

# ─── OCR ──────────────────────────────────────────────────────────
OCR_ENGINE=easyocr         # easyocr | paddleocr
OCR_LANGUAGES=en,hi

# ─── Whisper ──────────────────────────────────────────────────────
WHISPER_MODEL=tiny          # tiny | base | small
WHISPER_DEVICE=cpu          # cpu | cuda
WHISPER_LANGUAGE=           # leave empty for auto-detect
SAMPLE_RATE=16000
CHUNK_DURATION_S=5          # seconds per streaming chunk

# ─── Gesture ──────────────────────────────────────────────────────
GESTURE_MODEL_PATH=models/gesture/lstm_gesture.onnx
GESTURE_CLASSES=data/gesture/classes.txt
GESTURE_SEQUENCE_LEN=30    # frames per gesture sequence

# ─── TTS ──────────────────────────────────────────────────────────
TTS_ENGINE=pyttsx3          # pyttsx3 | gtts
TTS_RATE=175                # words per minute
TTS_VOLUME=1.0
ALERT_COOLDOWN_S=5          # seconds before same-object re-alert
