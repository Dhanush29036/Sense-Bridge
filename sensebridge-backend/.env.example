# ─── Server ───────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB ──────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/sensebridge
# Production: mongodb+srv://<user>:<password>@cluster.mongodb.net/sensebridge

# ─── JWT ──────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,capacitor://localhost

# ─── Rate Limiting ────────────────────────────────────
# Max requests per RATE_LIMIT_WINDOW_MS milliseconds
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
